include README.md
include requirements.txt
include requirements.lock
include RUN_PARALLEL_ACCEPTANCE.cmd
include scripts/preflight_check.py
include scripts/runtime_healthcheck.py
include scripts/run_candidate_factory.py
include scripts/run_parallel_acceptance.py
include scripts/update_shadow_ensemble_acceptance.py
recursive-include config *.yaml *.json
recursive-include docs *.md
recursive-include deployment *
recursive-include assets icon.ico icon.png
recursive-include src *.py
global-exclude .env .env.*
global-exclude *.py[cod] *$py.class
global-exclude *.sqlite *.sqlite3 *.db
global-exclude *.sqlite-wal *.sqlite-shm *.sqlite-journal
global-exclude *.sqlite3-wal *.sqlite3-shm *.sqlite3-journal
global-exclude *.db-wal *.db-shm *.db-journal
global-exclude build.log
global-exclude *.log
global-exclude okx_signal.lock
prune .pytest_cache
prune __pycache__
prune logs
prune output
prune outputs
include .env.example

# Deployment phase: observation permits market-data validation without formal push.
# Change to production only after a valid v3.56.12 approved manifest exists.
DEPLOYMENT_MODE=observation

SIGNAL_ONLY=true
DATA_READ_ONLY=true
OKX_IS_SIMULATED=true
OKX_AUTO_CLOSE_ENABLED=false

# Global notification emergency switch. Environment value overrides YAML.
FEISHU_ENABLED=false
FEISHU_WEBHOOK_URL=

# Do not configure private OKX credentials for this public-data signal system.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Persistent local paths on the VPS.
JIAOYI_DATA_DIR=/opt/okx-signal/app/outputs/runtime_cache
JIAOYI_RUNTIME_CACHE_DIR=/opt/okx-signal/app/outputs/runtime_cache

# Leave blank when the VPS can connect to OKX directly.
OKX_REST_PROXY=
OKX_WS_PROXY=

# Health status may be up to 20 minutes old because the formal signal cycle is 15m.
HEALTH_MAX_AGE_SECONDS=1200
PYTHONUTF8=1
PYTHONUNBUFFERED=1
